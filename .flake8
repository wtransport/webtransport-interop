[flake8]
max-line-length = 120
extend-ignore = E203, W503
exclude =
    *.egg
    *.egg-info
    .benchmarks
    .cache
    .eggs
    .git
    .github
    .mypy_cache
    .pytest_cache
    .tox
    .venv
    .vscode
    __pycache__
    build
    crates
    dist
    docs
    scripts
per-file-ignores =
    *.pyi: E302
